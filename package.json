{
  "name": "@karin-plugin-kkk/root",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "license": "GPL-3.0-only",
  "author": "ikenxuan",
  "type": "module",
  "scripts": {
    "build": "kkk build core web",
    "build:all": "kkk build core docs template",
    "build:core": "kkk build core",
    "build:docs": "kkk build docs",
    "build:template": "kkk build template",
    "dev": "pnpm --filter karin-plugin-kkk run dev",
    "docs": "pnpm --filter docs run dev",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "postinstall": "pnpm --filter @ikenxuan/amagi run build",
    "sort": "pnpm -r sort",
    "web": "pnpm --filter web run dev",
    "template": "pnpm --filter template run dev",
    "watch": "pnpm --filter karin-plugin-kkk run watch"
  },
  "dependencies": {
    "@ikenxuan/amagi": "workspace:*",
    "@tailwindcss/vite": "4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "node-karin": "1.16.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@kkk/cli": "workspace:*",
    "@tailwindcss/cli": "4.3.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/devtools": "^0.3.1",
    "cross-env": "10.1.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "sass-embedded": "^1.100.0",
    "sort-package-json": "^4.0.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "pnpm": {
    "overrides": {
      "node-karin": "$node-karin",
      "typescript": "$typescript",
      "react": "$react",
      "react-dom": "$react-dom",
      "vite": "$vite"
    },
    "onlyBuiltDependencies": [
      "@heroui/shared-utils",
      "@karinjs/sqlite3-cjs",
      "@parcel/watcher",
      "@swc/core",
      "cwebp-bin",
      "dtrace-provider",
      "esbuild",
      "gifsicle",
      "javascript-obfuscator",
      "jpegtran-bin",
      "mozjpeg",
      "msw",
      "optipng-bin",
      "pngquant-bin",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
