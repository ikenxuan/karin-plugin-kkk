{
  "name": "@karin-plugin-kkk/root",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "license": "GPL-3.0-only",
  "author": "ikenxuan",
  "type": "module",
  "scripts": {
    "build": "kkk build core web",
    "build:all": "kkk build core web docs",
    "build:core": "kkk build core",
    "build:docs": "kkk build docs",
    "build:template": "kkk build template",
    "dev": "pnpm --filter karin-plugin-kkk run dev",
    "docs": "pnpm --filter docs run dev",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "postinstall": "pnpm --filter @ikenxuan/amagi run build",
    "sort": "pnpm -r sort",
    "web": "pnpm --filter web run dev",
    "template": "pnpm --filter template run dev",
    "watch": "pnpm --filter karin-plugin-kkk run watch"
  },
  "dependencies": {
    "@ikenxuan/amagi": "workspace:*",
    "node-karin": "1.16.3"
  },
  "devDependencies": {
    "@kkk/cli": "workspace:*",
    "@types/node": "24.13.3",
    "cross-env": "10.1.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "sort-package-json": "^4.0.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "8.1.5"
  },
  "pnpm": {
    "overrides": {
      "node-karin": "$node-karin",
      "typescript": "$typescript",
      "vite": "$vite"
    },
    "onlyBuiltDependencies": [
      "@code-inspector/core",
      "@heroui/shared-utils",
      "@karinjs/sqlite3-cjs",
      "@parcel/watcher",
      "@swc/core",
      "cwebp-bin",
      "dtrace-provider",
      "esbuild",
      "gifsicle",
      "javascript-obfuscator",
      "jpegtran-bin",
      "mozjpeg",
      "node-pty",
      "optipng-bin",
      "pngquant-bin",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
