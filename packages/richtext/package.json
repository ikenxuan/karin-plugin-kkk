{
  "name": "@kkk/richtext",
  "version": "0.1.0",
  "description": "Rich text intermediate representation for karin-plugin-kkk — shared between core and template",
  "license": "GPL-3.0-only",
  "author": "ikenxuan",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./parse": {
      "types": "./src/parse/index.ts",
      "import": "./src/parse/index.ts"
    },
    "./react": {
      "types": "./src/react/index.tsx",
      "import": "./src/react/index.tsx"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17"
  }
}
