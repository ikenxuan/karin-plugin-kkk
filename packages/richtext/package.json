{
  "name": "@kkk/richtext",
  "version": "0.1.0",
  "description": "Rich text intermediate representation for karin-plugin-kkk — shared between core and template",
  "author": "ikenxuan",
  "license": "GPL-3.0-only",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./parse": {
      "types": "./src/parse/index.ts",
      "import": "./src/parse/index.ts"
    },
    "./react": {
      "types": "./src/react/index.tsx",
      "import": "./src/react/index.tsx"
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/"
  ],
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
